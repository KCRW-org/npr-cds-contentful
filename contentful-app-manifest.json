{
  "functions": [
    {
      "id": "nprCDSFunction",
      "name": "NPR CDS function",
      "description": "Handles NPR CDS resource lookup, search, GraphQL queries, and story publish/delete actions",
      "path": "functions/index.js",
      "entryFile": "functions/index.ts",
      "allowNetworks": ["content.api.npr.org", "stage-content.api.npr.org", "api.npr.org"],
      "accepts": [
        "resources.search", "resources.lookup",
        "graphql.resourcetype.mapping","graphql.query",
        "appaction.call"
      ]
    }
  ]
}